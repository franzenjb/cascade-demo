# ─────────────────────────────────────────────────────────────
# Project Cascade — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ─── Anthropic / Claude ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
# Model string — use the latest Claude model available
CLAUDE_MODEL=claude-sonnet-4-6

# ─── ArcGIS Online ───────────────────────────────────────────
AGOL_PORTAL_URL=https://arc-nhq-gis.maps.arcgis.com
AGOL_USERNAME=your_agol_username
AGOL_PASSWORD=your_agol_password

# Alternative: use a long-lived token instead of username/password
# AGOL_TOKEN=your_token_here

# ─── Layer Service URLs ──────────────────────────────────────
# These are populated by scripts/generate_cascade_data.py after publishing
# Example format:
# DEMO_CASCADE_BOUNDARY_URL=https://services.arcgis.com/abc123/arcgis/rest/services/DEMO_Cascade_Boundary/FeatureServer/0

DEMO_CASCADE_BOUNDARY_URL=
DEMO_CASCADE_ROADS_URL=
DEMO_CASCADE_CENSUS_TRACTS_URL=
DEMO_CASCADE_MOBILE_HOME_PARKS_URL=
DEMO_CASCADE_SCHOOLS_URL=
DEMO_CASCADE_MEDICAL_FACILITIES_URL=
DEMO_CASCADE_AFN_SERVICE_AREAS_URL=
DEMO_CASCADE_RED_CROSS_ASSETS_URL=
DEMO_CASCADE_HISTORICAL_INCIDENTS_URL=
DEMO_CASCADE_ACTIVE_WARNINGS_URL=

# ─── App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Cascade County Emergency Mapping Demo"
NEXT_PUBLIC_SHOW_TRIGGER_BUTTON=true
# Set to false for public deployments if you want to hide the trigger behind ?demo=1

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
# Options: debug | info | warn | error
